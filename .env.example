# Host IP to bind published ports to.
# - Default `127.0.0.1` is safest (host-only).
# - For phone access over Tailscale, set this to your host's Tailscale IPv4 (usually 100.x):
#   BIND_IP=$(tailscale ip -4 | head -n1)
BIND_IP=127.0.0.1

# Optional: allow the agent to relaunch this stack by SSHing into the host.
# This avoids mounting the Docker socket into containers.
#
# 1) Enable SSH on the host (macOS: System Settings -> Remote Login).
# 2) Set `STACK_SSH_TARGET` to a tailnet-reachable target.
# 3) Set `STACK_HOST_DIR` to the host path where this repo lives.
#
# STACK_SSH_TARGET=saejin@<host-tailnet-name>
# STACK_HOST_DIR=/Users/saejin/Projects/personal/viber
# STACK_SSH_IDENTITY_FILE=/home/coder/.config/agent/id_ed25519
# STACK_RELAUNCH_CMD=docker compose up -d --build

# llama.cpp model and runtime tuning
MODEL_FILE=Qwen-Coder-Next.gguf
LLAMA_CTX_SIZE=32768
LLAMA_PARALLEL=1
LLAMA_N_GPU_LAYERS=999

# Agent model defaults for OpenAI-compatible clients
OPENAI_MODEL=Qwen-Coder-Next.gguf
AIDER_MODEL=openai/Qwen-Coder-Next.gguf
QWEN_CODE_MODEL=Qwen-Coder-Next.gguf

# Default terminal command for ttyd
AGENT_CMD=bash

# Timezone inside containers
TZ=America/New_York

# Optional overrides:
# OPENAI_BASE_URL=http://llm-server:8081/v1
# OPENAI_API_KEY=dummy
